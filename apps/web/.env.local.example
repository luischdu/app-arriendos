# ============================================================
# ArriendosPRO - Web App Environment Variables
# Copia este archivo a .env.local y completa los valores
# ============================================================

# API Backend URL (Railway en prod, localhost en dev)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Nombre público de la app
NEXT_PUBLIC_APP_NAME=ArriendosPRO
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel Blob (persistencia de datos)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXX

# Analytics (opcional en desarrollo)
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
